{
  "name": "zntt-control",
  "version": "1.0.0",
  "productName": "zntt-control",
  "description": "Personal project management desktop app",
  "author": "zntt",
  "private": true,
  "scripts": {
    "dev": "quasar dev -m electron",
    "build": "quasar build -m electron",
    "build:installer": "cross-env npm_config_runtime=electron npm_config_target=28.3.3 CSC_IDENTITY_AUTO_DISCOVERY=false quasar build -m electron",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "lint": "eslint --ext .js,.vue ./"
  },
  "dependencies": {
    "@quasar/extras": "^1.16.0",
    "@vueuse/core": "^10.9.0",
    "better-sqlite3": "^9.4.0",
    "pinia": "^2.1.7",
    "quasar": "^2.16.0",
    "sortablejs": "^1.15.7",
    "vue": "^3.4.21",
    "vue-draggable-plus": "^0.6.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@quasar/app-webpack": "^3.13.0",
    "cross-env": "^10.1.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-vue": "^9.23.0",
    "png-to-ico": "^3.0.1",
    "prettier": "^3.2.5",
    "rcedit": "^5.0.2",
    "sass": "^1.71.1",
    "sass-loader": "^14.2.1"
  }
}
